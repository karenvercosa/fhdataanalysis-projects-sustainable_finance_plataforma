{
  "name": "sustainable-finance-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hub Digital (PWA) do evento Sustainable Finance 2026 — Goiânia, 04/09/2026",
  "scripts": {
    "dev": "node scripts/dev-next.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:up": "docker-compose up -d postgres redis",
    "infra:up": "docker-compose up -d --build",
    "infra:down": "docker-compose down",
    "sonar": "bash ./sonar/start.sh",
    "sonar:down": "docker compose -f sonar/docker-compose.yml down -v && docker volume rm -f sonar_sonar_db sonar_sonarqube_data sonar_sonarqube_extensions sonar_sonarqube_logs 2>/dev/null; true"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
